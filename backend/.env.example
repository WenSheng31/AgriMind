# 資料庫配置
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/agrimind

# JWT 配置
SECRET_KEY=your_jwt_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS 配置
BACKEND_CORS_ORIGINS=["http://127.0.0.1:8080", "http://localhost:5173"]

# MCP / Anthropic Claude API 配置
# 前往 https://console.anthropic.com/ 取得
ANTHROPIC_API_KEY=sk-ant-api03-...

# 中央氣象署開放資料平臺 API 配置
# 前往 https://opendata.cwa.gov.tw/ 申請
CWA_API_KEY=CWA-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# MCP 連線池
MCP_POOL_SIZE=1

# Google OAuth
# 前往 https://console.cloud.google.com/ 建立 OAuth 2.0 憑證
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# 管理員 Email 列表
ADMIN_EMAILS=["your_admin@example.com"]
